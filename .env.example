OPENAI_API_KEY=sk-your-key-heree
YOUTUBE_API_KEY=your-youtube-api-key-here
# Unsplash 高质量图片（免费 50 次/小时）
# https://unsplash.com/developers 注册获取
# Apple MapKit JS token（每天 25 万次免费，优先使用）
APPLE_MAPKIT_TOKEN=
# Google Maps（如果没有 Apple token 则自动使用，每月 $200 免费额度）
GOOGLE_MAPS_API_KEY=
# 可选：Instagram oEmbed（需要 Facebook App token）
# 没有 token 也能显示 Instagram 链接，只是没有缩略图
INSTAGRAM_TOKEN=
# 可选：Calendarific 节假日 API（覆盖 Nager.Date 不支持的国家）
CALENDARIFIC_API_KEY=
# Travelpayouts 联盟推广（机票+酒店 Widget）
# https://www.travelpayouts.com 注册，Dashboard 左下角找到 Marker ID
